#!/usr/bin/env bash
# bwssh â€” ssh/scp with the password auto-filled from Bitwarden.
# Sourced via the ssh/scp aliases set up in bwtkt-functions.sh.
#
# Config (~/.bwssh): lines of "<host-pattern> <object-id> [label...]"
#   (comma- or whitespace-separated; '#' comments allowed). Patterns are
#   matched as substrings of the destination host only â€” never against
#   option values, file names, or remote commands. Prefix a pattern with
#   '!' to skip the confirmation prompt for that host. The optional label
#   is shown in prompts instead of the raw object id.
#
# Commands to hosts with no matching entry run exactly like plain ssh/scp.

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
source "${SCRIPT_DIR}/../bwtkt-ui.sh"
UI_PREFIX=bwssh
BWSSH_CONFIG="${BWSSH_CONFIG:-$HOME/.bwssh}"

cmd=${@:1}

doBwssh() {
	local host=$1 objectId=$2 label=$3
	local password="" pin="" output=""

	if [[ "$(type -t bw)" == "function" ]]; then
		# bwtkt session-managed wrapper available
		if [[ ! -f /var/root/.bitwarden.session ]]; then
			ui_info "no Bitwarden session â€” logging in"
			if ! bw --regenerate-session-key; then
				ui_err "Bitwarden login failed"
				return 1
			fi
		fi
		# Read the session key once in this shell: the command substitutions
		# below run in subshells and would otherwise each prompt for sudo
		bw --prime-session
		if output=$(bw get password $objectId 2>&1); then
			# The wrapper may print session chatter before the password;
			# the password is always the last line.
			password="${output##*$'\n'}"
		elif [[ "$output" =~ (Invalid master password|Session key is invalid|mac failed|You are not logged in|Vault is locked|Token not found) ]]; then
			ui_warn "Bitwarden session invalid â€” regenerating"
			if bw --regenerate-session-key && output=$(bw get password $objectId 2>&1); then
				password="${output##*$'\n'}"
			fi
		fi
		if [[ -z "$password" ]]; then
			ui_err "could not fetch \"${label:-$objectId}\": ${output##*$'\n'}"
			ui_info "try: bw relogin"
			return 1
		fi
		pin=$(bw get totp $objectId 2>/dev/null)
		pin="${pin##*$'\n'}"
	else
		# Raw bw CLI fallback (no session management)
		password=$(command bw get password $objectId 2>/dev/null)
		password="${password##*$'\n'}"
		pin=$(command bw get totp $objectId 2>/dev/null)
		pin="${pin##*$'\n'}"
		if [[ -z "$password" ]]; then
			ui_err "could not fetch \"${label:-$objectId}\" â€” is the vault unlocked?"
			return 1
		fi
	fi

	ui_ok "autofilling password${pin:+ + TOTP} for \"${label:-${objectId:0:8}â€¦}\""
	# Secrets via the environment, not argv: /proc/*/cmdline is world-readable
	# and expect stays alive for the whole ssh session. Absolute expect path
	# avoids snap confinement issues.
	BWSSH_PASSWORD="$password" BWSSH_TOTP="$pin" /usr/bin/expect ${SCRIPT_DIR}/bwssh.expect "$cmd"
}

# Extract the destination host from an ssh/scp command line, so config
# patterns are matched only against the host actually being connected to â€”
# never against option values, file names, or remote commands.
_bwssh_target_host() {
	local prog valopts skip=0 arg target=""
	prog="$(basename "$1")"
	shift
	if [[ "$prog" == scp* ]]; then
		valopts=" -o -P -i -c -F -J -l -S -D -X "
	else
		valopts=" -b -B -c -D -E -e -F -I -i -J -L -l -m -o -O -p -Q -R -S -w -W "
	fi
	for arg in "$@"; do
		if (( skip )); then
			skip=0
			continue
		fi
		if [[ "$arg" == -* ]]; then
			[[ "$valopts" == *" $arg "* ]] && skip=1
			continue
		fi
		if [[ "$prog" == scp* ]]; then
			# remote spec looks like [user@]host:path
			if [[ "$arg" == *:* ]]; then
				target="${arg%%:*}"
				break
			fi
		else
			# first non-option argument is the ssh destination
			target="$arg"
			break
		fi
	done
	target="${target##*@}"
	target="${target#[}"
	target="${target%]}"
	echo "$target"
}

if [[ "$(which bw)" == "" ]]; then
	ui_err "bw command required â€” install from https://bitwarden.com/download/"
	$cmd
	return
fi

# No config file â†’ behave exactly like plain ssh/scp
if [[ ! -f "$BWSSH_CONFIG" ]]; then
	$cmd
	return
fi

# Scan the config for an entry matching targetHost. Sets matched/useConf and
# the conf* variables. assumeYes=1 skips the confirmation prompt (used right
# after the user has just chosen to link the host).
_bwssh_scan_config() {
	local assumeYes=${1:-0} pattern objectId label autoYes
	matched=0
	useConf=0
	confHost=""
	confId=""
	confLabel=""
	[[ -n "$targetHost" ]] || return 0
	while read -r pattern objectId label; do
		[[ -z "$pattern" || -z "$objectId" || "$pattern" == \#* ]] && continue
		autoYes=0
		if [[ "$pattern" == !* ]]; then
			autoYes=1
			pattern="${pattern#!}"
		fi
		if [[ "$targetHost" == *"$pattern"* ]]; then
			matched=1
			if (( autoYes || assumeYes )) || ui_confirm "$targetHost â€” autofill \"${label:-${objectId:0:8}â€¦}\"?"; then
				useConf=1
				confHost=$pattern
				confId=$objectId
				confLabel=$label
			fi
			break  # first match wins; never prompt twice
		fi
	done < <(tr ',' ' ' < "$BWSSH_CONFIG")
}

# First connection to a host with no config entry, on a terminal: offer â€”
# once per host, ever â€” to link it to a vault item on the spot. Declined or
# irrelevant hosts are remembered and never asked about again.
_bwssh_offer_link() {
	local cache="$HOME/.cache/bwtkt/offered-hosts" reply
	[[ -t 0 && -r /dev/tty ]] || return 1
	grep -qxF "$targetHost" "$cache" 2>/dev/null && return 1
	mkdir -p "${cache%/*}" && printf '%s\n' "$targetHost" >> "$cache"
	read -r -p "$(_ui_tag) no vault link for ${targetHost} â€” add one? [y/N] " reply < /dev/tty || return 1
	[[ "$reply" =~ ^[Yy]$ ]] || return 1
	"${SCRIPT_DIR}/../bin/bwtkt" add "$targetHost"
}

targetHost=$(_bwssh_target_host $cmd)
_bwssh_scan_config
if (( ! matched )) && _bwssh_offer_link; then
	_bwssh_scan_config 1  # pick up the fresh entry, no second question
fi

if (( useConf )); then
	# On credential failure, fall back to a plain connection so the user
	# can still type the password by hand
	doBwssh "$confHost" "$confId" "$confLabel" || $cmd
else
	$cmd
fi
