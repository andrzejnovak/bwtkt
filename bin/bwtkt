#!/usr/bin/env bash
# bwtkt — manage Bitwarden auto-login mappings for bwssh and binit.

BWTKT_DIR="$(dirname "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")")"
source "${BWTKT_DIR}/bwtkt-ui.sh"
UI_PREFIX=bwtkt

usage() {
	cat <<'EOF'
bwtkt — Bitwarden auto-login toolkit

Usage:
  bwtkt list                        show configured ssh hosts and kerberos principals
  bwtkt add <host-pattern> [term]   map an ssh host to a vault item; [term] seeds the
                                    vault search (defaults to the pattern itself)
  bwtkt add -k <pattern> [term]     map a kerberos principal instead (~/.binit)
  bwtkt doctor                      check the installation

Picking uses fzf when installed, a numbered list otherwise. A single search
hit just asks for confirmation. bwssh also offers to link unknown hosts on
first contact (once per host; declined hosts are remembered in
~/.cache/bwtkt/offered-hosts).

Config formats (whitespace- or comma-separated, '#' comments):
  ~/.bwssh    <host-pattern>  <object-id>  [label...]
  ~/.binit    <principal-pattern>  <object-id>  [label...]
              default  <principal>
Host patterns match on dot-label boundaries ("cern" matches lxplus.cern.ch,
never cern-fake.net). A '!' prefix skips the confirm prompt, honored only
when the pattern is the exact host.
EOF
}

_print_entries() {
	local heading=$1 conf=$2
	[[ -f "$conf" ]] || return 0
	echo "${_ui_bold}${heading}${_ui_reset}  ($conf)"
	local pattern id label flag
	while read -r pattern id label; do
		[[ -z "$pattern" || "$pattern" == \#* ]] && continue
		if [[ "$pattern" == "default" ]]; then
			printf '   %-30s %s\n' "(default principal)" "$id"
			continue
		fi
		flag=" "
		[[ "$pattern" == !* ]] && { flag="!"; pattern="${pattern#!}"; }
		printf '  %s%-30s %-24s %.8s…\n' "$flag" "$pattern" "${label:--}" "$id"
	done < <(tr ',' ' ' < "$conf")
}

cmd_list() {
	_print_entries "SSH hosts" "${BWSSH_CONFIG:-$HOME/.bwssh}"
	echo
	_print_entries "Kerberos principals" "${BINIT_CONFIG:-$HOME/.binit}"
	echo
	echo "${_ui_bold}Tips${_ui_reset}: '!' before a host pattern skips the confirmation prompt;"
	echo "the label column is optional and purely cosmetic."
}

cmd_add() {
	local conf="${BWSSH_CONFIG:-$HOME/.bwssh}"
	if [[ "$1" == "-k" ]]; then
		conf="${BINIT_CONFIG:-$HOME/.binit}"
		shift
	fi
	local pattern=$1
	shift
	if [[ -z "$pattern" ]]; then
		ui_err "usage: bwtkt add [-k] <pattern> [vault search term]"
		return 1
	fi
	if ! command -v jq &>/dev/null; then
		ui_err "jq is required for 'bwtkt add' — install it or edit $conf by hand"
		return 1
	fi

	# Get the session-managed bw() wrapper if it isn't loaded yet
	if [[ "$(type -t bw)" != "function" ]]; then
		if [[ -f ~/.config/bwtkt/bwtkt-user-init.sh ]]; then
			source ~/.config/bwtkt/bwtkt-user-init.sh
		else
			source "${BWTKT_DIR}/bwtkt-functions.sh"
		fi
	fi
	# One sudo prompt here; the searches below then run without sudo
	[[ "$(type -t bw)" == "function" ]] && bw --prime-session

	# Search term: extra arguments, else the pattern itself; re-prompt on
	# zero hits so a hostname that isn't an item name still gets there
	local term="${*:-$pattern}" items count
	while :; do
		ui_info "searching vault for \"$term\"…"
		items=$(bw list items --search "$term" 2>/dev/null | tail -1)
		count=$(jq 'length' <<<"$items" 2>/dev/null) || count=0
		(( count > 0 )) && break
		ui_warn "no vault items match \"$term\""
		read -r -p "$(_ui_tag) new search term (empty aborts): " term < /dev/tty || return 1
		[[ -n "$term" ]] || return 1
	done

	local id="" name="" idx=""
	if (( count == 1 )); then
		# Single hit: confirm instead of making the user pick from a list of one
		idx=0
		name=$(jq -r '.[0].name' <<<"$items")
		ui_confirm "link $pattern → \"$name\" [$(jq -r '.[0].login.username // "-"' <<<"$items")]?" || return 1
	elif command -v fzf &>/dev/null; then
		local sel
		sel=$(jq -r '.[] | "\(.name)\t\(.login.username // "-")\t\(.id)"' <<<"$items" |
			fzf --prompt="item for $pattern > " --with-nth=1,2 --delimiter=$'\t' --height=~40%) || return 1
		id="${sel##*$'\t'}"
	else
		local -a lines
		mapfile -t lines < <(jq -r '.[] | "\(.name)   [\(.login.username // "-")]"' <<<"$items")
		local i sel
		for ((i = 0; i < count; i++)); do
			printf '  %2d) %s\n' $((i + 1)) "${lines[i]}"
		done
		read -r -p "$(_ui_tag) item number: " sel < /dev/tty || return 1
		if ! [[ "$sel" =~ ^[0-9]+$ ]] || (( sel < 1 || sel > count )); then
			ui_err "invalid selection"
			return 1
		fi
		idx=$((sel - 1))
	fi

	if [[ -n "$idx" ]]; then
		id=$(jq -r ".[$idx].id" <<<"$items")
		name=$(jq -r ".[$idx].name" <<<"$items")
	else
		name=$(jq -r --arg id "$id" '.[] | select(.id == $id).name' <<<"$items")
	fi
	# Vault item names are free text — flatten whitespace so a crafted name
	# can't inject extra config lines
	name="${name//[$'\n\r\t']/ }"
	printf '%s  %s  %s\n' "$pattern" "$id" "$name" >> "$conf"
	chmod 600 "$conf" 2>/dev/null
	ui_ok "added: $pattern → \"$name\"  ($conf)"
}

cmd_doctor() {
	local fails=0

	_have() {
		if command -v "$1" &>/dev/null; then
			ui_ok "$1 found ($(command -v "$1"))"
		else
			ui_err "$1 not found${2:+ — $2}"
			(( fails++ ))
		fi
	}
	_have bw "install from https://bitwarden.com/download/"
	_have expect "needed by bwssh"
	_have kinit "needed by binit"
	_have jq "needed by 'bwtkt add' (optional)"

	if [[ -f ~/.config/bwtkt/bwtkt-user-init.sh ]]; then
		ui_ok "user init script present (~/.config/bwtkt/bwtkt-user-init.sh)"
		if grep -qF "bwtkt-user-init.sh" ~/.bashrc 2>/dev/null; then
			ui_ok "sourced from ~/.bashrc"
		else
			ui_warn "not referenced in ~/.bashrc — run setup.sh"
		fi
	else
		ui_warn "no user init script — run setup.sh"
	fi

	local conf
	for conf in "${BWSSH_CONFIG:-$HOME/.bwssh}" "${BINIT_CONFIG:-$HOME/.binit}"; do
		if [[ -f "$conf" ]]; then
			local perms
			perms=$(stat -c '%a' "$conf" 2>/dev/null)
			if [[ "$perms" == 600 ]]; then
				ui_ok "$conf present (0600)"
			else
				ui_warn "$conf has mode $perms — consider: chmod 600 $conf"
			fi
		else
			ui_warn "$conf not configured"
		fi
	done

	if sudo -n test -f /var/root/.bitwarden.session 2>/dev/null; then
		local sperms
		sperms=$(sudo -n stat -c '%a %U' /var/root/.bitwarden.session 2>/dev/null)
		if [[ "$sperms" == "600 root" ]]; then
			ui_ok "session file present (0600 root)"
		else
			ui_err "session file has '$sperms' — run: sudo chmod 600 /var/root/.bitwarden.session"
			(( fails++ ))
		fi
		sudo -k
	else
		ui_info "session file not checked (needs sudo) — run 'sudo true' first to verify it"
	fi

	(( fails == 0 )) && ui_ok "all required checks passed" || ui_err "$fails problem(s) found"
	return $(( fails > 0 ))
}

case "$1" in
	list) cmd_list ;;
	add) shift; cmd_add "$@" ;;
	doctor) cmd_doctor ;;
	-h | --help | help | '') usage ;;
	*)
		ui_err "unknown command: $1"
		usage
		exit 1
		;;
esac
